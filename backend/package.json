{
  "name": "wechat-promotion-backend",
  "version": "1.0.0",
  "description": "微信公众号推广系统 - 后端服务",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "init-admin": "ts-node src/scripts/initAdmin.ts",
    "migrate-employee-binding": "ts-node src/scripts/migrateEmployeeBinding.ts",
    "migrate-employee-info": "ts-node src/scripts/migrateEmployeeInfo.ts",
    "sync": "ts-node src/scripts/syncStatus.ts",
    "test-api": "ts-node src/scripts/testApi.ts",
    "test-wechat": "ts-node src/scripts/testWechat.ts",
    "install-sms": "npm install @alicloud/dysmsapi20170525 @alicloud/openapi-client",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["wechat", "promotion", "employee"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^3.0.1",
    "@alicloud/openapi-client": "^0.4.6",
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2"
  }
