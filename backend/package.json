{
  "name": "wechat-promotion-backend",
  "version": "1.0.0",
  "description": "微信公众号推广系统 - 后端服务",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc && npm run copy-public",
    "build:full": "npm run build:frontend && npm run build",
    "build:frontend": "cd ../frontend && npm install && npm run build && xcopy dist ..\\backend\\public /E /I /Y",
    "start": "node dist/app.js",
    "init-admin": "ts-node src/scripts/initAdmin.ts",
    "migrate-employee-binding": "ts-node src/scripts/migrateEmployeeBinding.ts",
    "migrate-employee-info": "ts-node src/scripts/migrateEmployeeInfo.ts",
    "sync": "ts-node src/scripts/syncStatus.ts",
    "test-api": "ts-node src/scripts/testApi.ts",
    "test-wechat": "ts-node src/scripts/testWechat.ts",
    "install-sms": "npm install @alicloud/dysmsapi20170525 @alicloud/openapi-client",
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy-public": "xcopy /E /I /Y public dist\\\\public",
    "railway-build": "npm install --legacy-peer-deps && tsc && npm run copy-public"
  },
  "keywords": [
    "wechat",
    "promotion",
    "employee"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^3.0.1",
    "@alicloud/openapi-client": "^0.4.6",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.5",
    "qrcode": "^1.5.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
