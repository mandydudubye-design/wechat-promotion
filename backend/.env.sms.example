# ============================================
# 阿里云短信服务配置
# ============================================

# 阿里云AccessKey（在阿里云控制台获取）
ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here

# 短信签名（需要在阿里云短信服务中申请）
ALIYUN_SMS_SIGN_NAME=你的公司名

# 短信模板代码（需要在阿里云短信服务中申请）
# 模板内容：您的验证码是${code}，5分钟内有效。
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# H5页面URL（用于公众号菜单配置）
H5_URL=https://your-domain.com

# ============================================
# 配置说明
# ============================================

# 1. 获取阿里云AccessKey
#    - 登录阿里云控制台：https://www.aliyun.com
#    - 进入"AccessKey管理"
#    - 创建AccessKey（建议使用RAM子账号）
#    - 复制AccessKey ID和Secret

# 2. 申请短信签名
#    - 进入"短信服务"控制台
#    - 点击"国内消息" → "签名管理"
#    - 添加签名（公司名或产品名）
#    - 等待审核（1-2小时）

# 3. 申请短信模板
#    - 进入"模板管理"
#    - 添加模板：
#      模板类型：验证码
#      模板名称：员工验证
#      模板内容：您的验证码是${code}，5分钟内有效。
#      应用场景：员工身份验证
#    - 等待审核（1-2小时）
#    - 复制模板代码

# 4. 配置环境变量
#    - 将上面的配置替换为实际值
#    - 重新启动后端服务

# 5. 测试发送
#    - 使用Postman或curl测试接口
#    - POST http://localhost:3000/api/employee-binding/send-code
#    - Body: {"phone":"13800138000"}

# ============================================
# 费用说明
# ============================================

# 短信费用：¥0.045/条
# 100人验证一次：¥4.5
# 每月10人新验证：¥0.45

# ============================================
# 注意事项
# ============================================

# 1. 不要将AccessKey提交到代码仓库
# 2. 生产环境使用RAM子账号，只授予短信服务权限
# 3. 短信签名和模板需要审核，请提前申请
# 4. 验证码5分钟有效，防止重复发送（60秒限制）
