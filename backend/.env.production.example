# 微信公众号配置
# 登录微信公众平台（mp.weixin.qq.com）→ 开发 → 基本配置
WECHAT_APP_ID=wx你的AppID
WECHAT_APP_SECRET=你的AppSecret
WECHAT_TOKEN=your_token_here（自定义，需要与微信后台配置一致）
WECHAT_ENCODING_AES_KEY=随机生成的EncodingAESKey（32位随机字符串）

# 服务器配置
SERVER_URL=https://x-bussiness.online
WEBHOOK_PATH=/api/wechat/webhook

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL root密码（请修改）
DB_NAME=wechat_promotion

# 服务器配置
PORT=3000

# JWT 配置（生成随机字符串）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=生成一个64位随机字符串并填在这里
JWT_EXPIRES_IN=7d

# 生产环境标识
NODE_ENV=production
